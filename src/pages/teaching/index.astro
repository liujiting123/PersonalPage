---
import BaseListing from "../../layouts/BaseListing.astro";
import { PAGES } from "../../config";
import { withBase } from "../../utils/paths";

if (PAGES.teaching.isActive === false) {
    return Astro.redirect(withBase("/404"));
}

const { title, subtitle } = PAGES.teaching;
---

<BaseListing collection="teaching" title={title} subtitle={subtitle} />
