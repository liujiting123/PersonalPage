---
import { getCollection } from "astro:content";
import BaseDetail from "../../layouts/BaseDetail.astro";
import { PAGES } from "../../config";
import { withBase } from "../../utils/paths";

if (PAGES.teaching.isActive === false) {
    return Astro.redirect(withBase("/404"));
}

export async function getStaticPaths() {
    if (PAGES.teaching.isActive === false) return [];
    const entries = await getCollection("teaching");
    return entries.map((entry) => ({
        params: { id: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
---

<BaseDetail collection="teaching" id={entry.id} />
