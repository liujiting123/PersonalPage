---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { PAGES } from "../config";

// Load bio content
const bioEntry = await getEntry("bio", "bio");
const { Content: BioContent } = bioEntry
	? await render(bioEntry)
	: { Content: null };
---

<BaseLayout title={PAGES.home.title}>
	<div class="container-narrow">
		<section class="news-banner" aria-label="News">
			<p class="news-banner-label">News</p>
			<p class="news-banner-text">
				I am currently seeking <strong>PhD opportunities for Fall 2028 entry</strong> in <strong>Embodied AI</strong>, <strong>Spatial Intelligence</strong>, and <strong>Multimodal Learning</strong>.
			</p>
		</section>
		{
			(PAGES.home.title || PAGES.home.subtitle) && (
				<header class="page-header">
					{PAGES.home.title && (
						<h1 class="page-title">{PAGES.home.title}</h1>
					)}
					{PAGES.home.subtitle && (
						<p class="page-subtitle">{PAGES.home.subtitle}</p>
					)}
				</header>
			)
		}
		<div class="prose">
			{BioContent ? <BioContent /> : <p>Loading bio...</p>}
		</div>
	</div>
</BaseLayout>
