---
import { getCollection } from "astro:content";
import BaseDetail from "../../layouts/BaseDetail.astro";
import { PAGES } from "../../config";
import { withBase } from "../../utils/paths";

if (PAGES.talks.isActive === false) {
    return Astro.redirect(withBase("/404"));
}

export async function getStaticPaths() {
    if (PAGES.talks.isActive === false) return [];
    const talks = await getCollection("talks");
    return talks.map((talk: any) => ({
        params: { id: talk.id },
        props: { talk },
    }));
}

const { id } = Astro.params;
---

<BaseDetail collection="talks" id={id} />
