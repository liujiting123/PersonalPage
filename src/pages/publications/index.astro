---
import BaseListing from "../../layouts/BaseListing.astro";
import { PAGES } from "../../config";
import { withBase } from "../../utils/paths";

if (PAGES.publications.isActive === false) {
    return Astro.redirect(withBase("/404"));
}
---

<BaseListing
    collection="publications"
    title={PAGES.publications.title}
    subtitle={PAGES.publications.subtitle}
/>
