---
import { SETTINGS } from "../../config";
import DevToolsLayout from "../../layouts/DevToolsLayout.astro";
import { withBase } from "../../utils/paths";

const redirect: boolean = import.meta.env.PROD && !SETTINGS.addDevToolsInProduction;
if (redirect) {
    return Astro.redirect(withBase("/404"));
}

const visualizers = [
    {
        name: "Palette Visualizer",
        path: withBase("/dev-tools/palette-visualizer"),
        desc: "Interactive view of all light and dark theme color palettes.",
    },
    {
        name: "Screen Visualizer",
        path: withBase("/dev-tools/screen-visualizer"),
        desc: "Grid of preview frames for different device sizes (Mobile, Tablet, Desktop).",
    },
    {
        name: "Theme Visualizer",
        path: withBase("/dev-tools/theme-visualizer"),
        desc: "Live comparison of the active light and dark theme configurations.",
    },
    {
        name: "Simple Theme Visualizer",
        path: withBase("/dev-tools/simple-theme-visualizer"),
        desc: "Simplified preview of theme colors with sample UI elements.",
    },
];
---

<DevToolsLayout title="Index" description="Internal utilities for UI/UX verification and theme debugging.">

            <div class="item-list">
                {
                    visualizers.map((tool) => (
                        <div class="card">
                            <a href={tool.path} class="card-title">
                                {tool.name}
                            </a>
                            <p class="card-desc">
                                {tool.desc}
                            </p>
                        </div>
                    ))
                }
            </div>

            <footer
                class="mt-20 pt-8 text-text-muted text-sm"
            >
                <p>
                    Note: These tools are only accessible in development mode.
                </p>
            </footer>
</DevToolsLayout>
